{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": "./",
    "outDir": "./dist"
  },
  "include": [
    "./test",
    "./scripts",
    "./deploy",
    "./src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}